# Copy to ~/.config/temperance/temperance.env for local secrets.
# Keep real credentials out of the repository tree.

GARMIN_EMAIL="you@example.com"
GARMIN_PASSWORD="replace_with_real_password_outside_repo"

TEMPERANCE_AUTH_ENABLED="1"
TEMPERANCE_ADMIN_USER="admin"
TEMPERANCE_ADMIN_PASSWORD="replace_with_real_admin_password_outside_repo"
TEMPERANCE_VIEWER_USERS="viewer"

TEMPERANCE_AUTO_SYNC_ENABLED="0"
TEMPERANCE_AUTO_SYNC_INTERVAL_SECONDS="900"
TEMPERANCE_AUTO_SYNC_OWNER="admin"
TEMPERANCE_AUTO_SYNC_DAYS_BACK="14"

TEMPERANCE_AUTH_COOKIE_SECRET="replace_with_long_random_secret_outside_repo"
